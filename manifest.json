{
  "manifest_version": 3,
  "name": "GCal Duration Badge",
  "version": "2.0.0",
  "description": "Shows event duration and live countdown directly inside Google Calendar.",

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "https://calendar.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": []
}
